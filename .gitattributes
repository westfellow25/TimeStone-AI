# Normalize line endings — keeps git diffs clean across Windows/macOS/Linux
* text=auto eol=lf

# Force LF for source files
*.py text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.pdf binary

# Copy this file to .env and fill in your secrets.
# Never commit the real .env (it is gitignored).

# Required only if you want Claude-generated scenarios.
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional — override default model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional — Monte Carlo defaults
# TIMESTONE_DISCOUNT_RATE=0.12
# TIMESTONE_HORIZON_YEARS=5
# TIMESTONE_ITERATIONS=1000
